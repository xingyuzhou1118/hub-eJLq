def calculate_overtime_pay(hours_worked: float, hourly_rate: float, overtime_multiplier: float = 1.5) -> Dict[str, Any]:
    """
    计算加班费的自定义工具
    """
    if hours_worked <= 0 or hourly_rate <= 0:
        return {
            "status": "error",
            "message": "工作小时数和时薪必须大于0"
        }
    
    regular_hours = min(hours_worked, 8)  # 假设每天8小时为正常工作时间
    overtime_hours = max(0, hours_worked - 8)
    
    regular_pay = regular_hours * hourly_rate
    overtime_pay = overtime_hours * hourly_rate * overtime_multiplier
    total_pay = regular_pay + overtime_pay
    
    return {
        "status": "success",
        "regular_hours": regular_hours,
        "overtime_hours": overtime_hours,
        "regular_pay": round(regular_pay, 2),
        "overtime_pay": round(overtime_pay, 2),
        "total_pay": round(total_pay, 2)
    }

